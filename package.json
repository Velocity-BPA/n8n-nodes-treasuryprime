{
  "name": "n8n-nodes-treasuryprime",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Treasury Prime BaaS platform providing 25 resources and 200+ operations for banking-as-a-service automation including accounts, ACH, wires, cards, compliance, and real-time webhooks.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-treasuryprime.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-treasuryprime#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-treasuryprime/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "treasury-prime",
    "baas",
    "banking-as-a-service",
    "fintech",
    "ach",
    "wire-transfer",
    "card-issuing",
    "compliance",
    "kyc",
    "kyb",
    "accounts",
    "payments",
    "banking",
    "automation",
    "workflow"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TreasuryPrimeApi.credentials.js",
      "dist/credentials/TreasuryPrimeOAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TreasuryPrime/TreasuryPrime.node.js",
      "dist/nodes/TreasuryPrime/TreasuryPrimeTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "copyfiles -u 1 \"nodes/**/*.svg\" \"nodes/**/*.png\" dist/",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.20.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
